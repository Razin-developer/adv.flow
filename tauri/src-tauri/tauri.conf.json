{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Adv.Flow",
  "version": "1.0.0",
  "identifier": "com.advflow.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",



    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Adv.flow",
        "width": 1440,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 760,
        "resizable": true,
        "backgroundColor": "#0f172a"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "externalBin": [
      "binaries/advflow-cli"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "./windows/nsis-hooks.nsh",
        "installMode": "currentUser"
      }
    }
  }
}
